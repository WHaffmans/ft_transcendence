# Cloudflare Tunnel Configuration
# Get your tunnel token from: https://one.dash.cloudflare.com/ -> Access -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=

# ============================================================================
# Production Domain Configuration (via Cloudflare Tunnel)
# ============================================================================
PROD_DOMAIN=
PROD_OAUTH_REDIRECT=
PROD_BACKEND_INTERNAL_BASE_URL=https://backend-service:4443/internal
PROD_AUTH_SERVICE_URL=https://backend-service:4443

# ============================================================================
# Production Social OAuth (transcendence.duinvoetje.nl)
# Register at: https://github.com/settings/developers
# Callback URL: https://transcendence.duinvoetje.nl/auth/callback/github
# ============================================================================
PROD_GITHUB_CLIENT_ID=
PROD_GITHUB_CLIENT_SECRET=

# Register at: https://profile.intra.42.fr/oauth/applications
# Callback URL: https://transcendence.duinvoetje.nl/auth/callback/intra
PROD_INTRA_CLIENT_ID=
PROD_INTRA_CLIENT_SECRET=



# ============================================================================
# Development Domain Configuration (localhost)
# ============================================================================
DOMAIN=localhost:8080
OAUTH_REDIRECT=http://localhost:8080/auth/oauth/callback
BACKEND_INTERNAL_BASE_URL=http://backend-service:4000/internal
AUTH_SERVICE_URL=http://backend-service:4000

# ============================================================================
# Development Social OAuth (localhost:8080)
# Register at: https://github.com/settings/developers
# Callback URL: http://localhost:8080/auth/callback/github
# ============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Register at: https://profile.intra.42.fr/oauth/applications
# Callback URL: http://localhost:8080/auth/callback/intra
INTRA_CLIENT_ID=
INTRA_CLIENT_SECRET=



# ============================================================================
# General Configuration
# ============================================================================
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=

OAUTH_CLIENT_ID=

MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=

DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BACKEND_INTERNAL_API_KEY=
